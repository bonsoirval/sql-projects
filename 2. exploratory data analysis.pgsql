{"cells":[{"value":"/*\n* Check for null values  \n*/\n-- no null from encounters0\n\n\nSELECT\n    COUNT(*) - COUNT(id) AS null_id,\n    COUNT(*) - COUNT(start) AS null_start,\n    COUNT(*) - COUNT(stop) AS null_stop,\n    COUNT(*) - COUNT(patient) AS null_patient,\n    COUNT(*) - COUNT(organization) AS null_organization,\n    COUNT(*) - COUNT(payer) AS null_payer\nFROM encounters0;","kind":"sql","language":"sql"},{"value":"\nSELECT\n    COUNT(*) - COUNT(id) AS null_id,\n    COUNT(*) - COUNT(birthdate) AS null_birthdate,\n    COUNT(*) - COUNT(deathdate) AS null_deathdate,\n    count(*) - count(prefix) as null_prefix,\n    count(*) - count(\"first\") as null_first,\n    count(*) - count(\"last\") as null_last,\n    count(*) - count(suffix) as null_suffix,\n    count(*) - count(maiden) as null_maiden,\n    count(*) - count(marital) as null_marital,\n    count(*) - count(race) as null_race,\n    count(*) - count(ethnicity) as null_ethnicity,\n    count(*) - count(gender) as null_gender,\n    count(*) - count(birthplace) as null_birthplace\nFROM patients0;","kind":"sql","language":"sql"},{"value":"\nSELECT\n    COUNT(*) - COUNT(id) AS null_id,\n    COUNT(*) - COUNT(name) AS null_name,\n    COUNT(*) - COUNT(address) AS null_address,\n    COUNT(*) - COUNT(city) AS null_city,\n    COUNT(*) - COUNT(state_headquartered) as null_staate_headquarters,\n    COUNT(*) - COUNT(zip) AS null_zip,\n    COUNT(*) - COUNT(phone) AS null_phones\nFROM payers0;","kind":"sql","language":"sql"},{"value":"SELECT\n    COUNT(*) - COUNT(start) AS null_start,\n    count(*) - count(stop) as null_stop,\n    count(*) - count(patient) as null_patient,\n    count(*) - count(encounter) as null_encounter,\n    count(*) - count(code) as null_code,\n    count(*) - count(description) as null_description\nfrom procedures0;","kind":"sql","language":"sql"}],"metadata":{"connectionId":"1772718987289","databaseName":"hospital","host":"localhost","port":5432,"username":"njoku","custom":{"cells":[{"value":"/*\n* 